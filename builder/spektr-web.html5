<!DOCTYPE html>
<html lang="$if(lang)$$lang$$else$ru$endif$"$if(dir)$ dir="$dir$"$endif$>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="color-scheme" content="light dark">
<title>$if(pagetitle)$$pagetitle$$else$СПЕКТР$endif$</title>
$if(description)$<meta name="description" content="$description$">$endif$
<meta name="author" content="Редакция «СПЕКТРА»">
<link rel="icon" href="data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%2016%2016%22%3E%3Crect%20width%3D%2216%22%20height%3D%2216%22%20fill%3D%22%23fff%22%2F%3E%3Crect%20y%3D%222%22%20width%3D%2216%22%20height%3D%221.5%22%20fill%3D%22%23e4572e%22%2F%3E%3Crect%20y%3D%223.5%22%20width%3D%2216%22%20height%3D%221.5%22%20fill%3D%22%23f4a83a%22%2F%3E%3Crect%20y%3D%225%22%20width%3D%2216%22%20height%3D%221.5%22%20fill%3D%22%23f5d23c%22%2F%3E%3Crect%20y%3D%226.5%22%20width%3D%2216%22%20height%3D%221.5%22%20fill%3D%22%234caf6d%22%2F%3E%3Crect%20y%3D%228%22%20width%3D%2216%22%20height%3D%221.5%22%20fill%3D%22%231aa3b0%22%2F%3E%3Crect%20y%3D%229.5%22%20width%3D%2216%22%20height%3D%221.5%22%20fill%3D%22%233b6fd1%22%2F%3E%3Crect%20y%3D%2211%22%20width%3D%2216%22%20height%3D%221.5%22%20fill%3D%22%238a4fd0%22%2F%3E%3Crect%20y%3D%2212.5%22%20width%3D%2216%22%20height%3D%221.5%22%20fill%3D%22%23e4572e%22%2F%3E%3C%2Fsvg%3E">
<meta property="og:type" content="article">
<meta property="og:locale" content="ru_RU">
<meta property="og:site_name" content="СПЕКТР">
<meta property="og:title" content="$if(pagetitle)$$pagetitle$$else$СПЕКТР$endif$">
$if(description)$<meta property="og:description" content="$description$">$endif$
<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="$if(pagetitle)$$pagetitle$$else$СПЕКТР$endif$">
$if(description)$<meta name="twitter:description" content="$description$">$endif$
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "#org",
      "name": "Редакция «СПЕКТРА»",
      "description": "Научно-популярный журнал об аутизме для родителей."
    },
    {
      "@type": "Periodical",
      "@id": "#periodical",
      "name": "СПЕКТР",
      "inLanguage": "ru",
      "publisher": { "@id": "#org" },
      "about": "Аутизм: наука, практика, живые истории"
    },
    {
      "@type": "PublicationIssue",
      "@id": "#issue",
      "isPartOf": { "@id": "#periodical" },
      "issueNumber": "$issue$",
      "datePublished": "$date$",
      "inLanguage": "ru",
      "publisher": { "@id": "#org" }
    },
    {
      "@type": "ItemList",
      "name": "Содержание выпуска №$issue$",
      "inLanguage": "ru",
      "isPartOf": { "@id": "#issue" },
      "itemListOrder": "https://schema.org/ItemListOrderAscending",
      "numberOfItems": 8,
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "От редакции", "url": "#от-редакции" },
        { "@type": "ListItem", "position": 2, "name": "Главное за месяц", "url": "#главное-за-месяц" },
        { "@type": "ListItem", "position": 3, "name": "Наука понятным языком", "url": "#наука-понятным-языком" },
        { "@type": "ListItem", "position": 4, "name": "Подходы и практика", "url": "#подходы-и-практика" },
        { "@type": "ListItem", "position": 5, "name": "Живые истории", "url": "#живые-истории" },
        { "@type": "ListItem", "position": 6, "name": "Культура и медиа", "url": "#культура-и-медиа" },
        { "@type": "ListItem", "position": 7, "name": "Родителю на заметку", "url": "#родителю-на-заметку" },
        { "@type": "ListItem", "position": 8, "name": "Источники", "url": "#источники" }
      ]
    }
  ]
}
</script>
<style>
  /* ============ ДИЗАЙН-ТОКЕНЫ ============ */
  :root{
    --ink:#181a1f;        /* заголовки */
    --body:#2b2e34;       /* основной текст */
    --muted:#6c7178;      /* подписи, мета */
    --rule:#e6e6e2;       /* тонкие линейки */
    --paper:#ffffff;
    --card:#eef6f6;       /* фон врезок (лёгкий тиал) */
    --accent:#0e7490;     /* основной цвет: ссылки, рубрики */
    --accent-2:#3b4f9e;   /* вторичный: конец градиента */
    --accent-ink:#0a5566; /* :hover */
    /* цветовые остановки фирменного спектра */
    --spectrum-stops:
      #e4572e 0%, #f4a83a 17%, #f5d23c 33%, #4caf6d 50%,
      #1aa3b0 67%, #3b6fd1 83%, var(--accent-2) 100%;
    --serif: Georgia, "PT Serif", "Noto Serif", "Times New Roman", serif;
    --sans: system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    --measure: 46rem;
  }
  @media (prefers-color-scheme: dark){
    :root{
      --ink:#f0efec; --body:#dcdad4; --muted:#9a958c; --rule:#33322f;
      --paper:#15161a; --card:#16262b;
      --accent:#5fb3c4; --accent-2:#9aa8e6; --accent-ink:#8fd0dd;
    }
  }

  *{ box-sizing:border-box; }
  html{ -webkit-text-size-adjust:100%; overflow-x:hidden; }
  /* плавная прокрутка — только для тех, кто хорошо переносит анимацию */
  @media (prefers-reduced-motion: no-preference){
    html{ scroll-behavior:smooth; }
  }
  body{
    margin:0; background:var(--paper); color:var(--body);
    font-family:var(--serif);
    font-size: clamp(1.0625rem, 1rem + 0.35vw, 1.1875rem);
    line-height:1.7; text-rendering:optimizeLegibility;
    -webkit-font-smoothing:antialiased;
    overflow-wrap:break-word; word-break:normal;
  }
  .page{ max-width:var(--measure); margin:0 auto; padding:2.2rem 1.25rem 4rem; }

  /* ============ МАСТХЕД / ОБЛОЖКА ============ */
  h1{
    position:relative; padding-left:.85rem;
    font-family:var(--sans); font-weight:800; color:var(--ink);
    font-size: clamp(2.6rem, 11vw, 4.4rem); line-height:.95;
    letter-spacing:-.02em; margin:0 0 .15em;
  }
  h1::before{
    content:""; position:absolute; left:0; top:.15em; height:.75em;
    width:6px;
    background:linear-gradient(180deg, var(--spectrum-stops));
  }
  /* фирменная спектральная полоса-индикатор прогресса чтения (заполняется при скролле) */
  .reading-progress{
    position:fixed; top:0; left:0; right:0; z-index:200;
    height:4px; background:transparent;
  }
  .reading-progress span{
    display:block; width:0; height:100%;
    background:linear-gradient(90deg, var(--spectrum-stops));
  }
  /* кнопка «наверх» — появляется при скролле */
  .back-to-top{
    position:fixed; right:1.25rem; bottom:1.25rem; z-index:100;
    display:flex; align-items:center; justify-content:center;
    gap:.55rem;
    min-width:0; height:2.75rem; padding:0 1rem 0 .85rem;
    color:#fff; background:var(--accent);
    border:0; border-radius:999px;
    font-family:var(--sans); font-size:.98rem; font-weight:600; line-height:1;
    text-decoration:none; white-space:nowrap; cursor:pointer;
    box-shadow:0 6px 18px color-mix(in srgb, var(--ink) 18%, transparent);
    opacity:0; pointer-events:none;
    transform:translateY(.5rem);
    transition:opacity .2s ease, transform .2s ease, background-color .2s ease, box-shadow .2s ease;
  }
  .back-to-top__icon{
    font-size:1.35rem; font-weight:700; line-height:1;
    transform:translateY(-.03em);
  }
  .back-to-top.is-visible{
    opacity:1; pointer-events:auto;
    transform:translateY(0);
  }
  .back-to-top:hover,
  .back-to-top:focus-visible{
    color:#fff; background:var(--accent-ink);
    box-shadow:0 8px 22px color-mix(in srgb, var(--ink) 22%, transparent);
  }
  .back-to-top:focus-visible{
    outline:3px solid var(--accent); outline-offset:3px;
  }
  @media (prefers-reduced-motion: reduce){
    .back-to-top{ transition:none; }
  }
  @media (max-width:560px){
    .back-to-top{ right:1rem; bottom:1rem; height:2.55rem; padding:0 .9rem 0 .75rem; font-size:.92rem; }
    .back-to-top__icon{ font-size:1.2rem; }
  }
  /* дескриптор под названием */
  h1 + .deck{
    font-family:var(--sans); font-weight:700; text-transform:uppercase;
    letter-spacing:.08em; font-size:.78rem; color:var(--accent);
    margin:.2rem 0 1.2rem;
  }
  /* дата выпуска и колофон — приглушённый служебный текст */
  .date, .colophon{
    font-family:var(--sans); font-size:.85rem; color:var(--muted);
  }

  /* ============ РУБРИКИ (## 01 · ...) ============ */
  h2{
    font-family:var(--sans); font-weight:800; color:var(--ink);
    font-size: clamp(1.5rem, 5vw, 2.05rem); line-height:1.1;
    letter-spacing:-.01em; margin:3.4rem 0 1.4rem; padding-top:1rem;
    border-top:3px solid var(--accent); scroll-margin-top:1rem;
  }
  /* секции от --section-divs: якорь оглавления ведёт на <section> */
  section[id]{ scroll-margin-top:1rem; }
  /* ============ ПОДЗАГОЛОВКИ (### ...) ============ */
  h3{
    font-family:var(--sans); font-weight:700; color:var(--ink);
    font-size: clamp(1.18rem, 3.4vw, 1.42rem); line-height:1.25;
    margin:2.4rem 0 .2rem; scroll-margin-top:1rem;
  }
  /* ============ ЗАГОЛОВКИ-ЛИДЫ (из жирного абзаца) ============ */
  h4{
    font-family:var(--sans); font-weight:700; color:var(--ink);
    font-size:1.12em; line-height:1.28; margin:1.7rem 0 .5rem;
  }

  /* ============ СЛУЖЕБНЫЕ КЛАССЫ (a11y) ============ */
  /* visually hidden, но доступно скринридерам */
  .sr-only{
    position:absolute; width:1px; height:1px; padding:0; margin:-1px;
    overflow:hidden; clip:rect(0,0,0,0); white-space:nowrap; border:0;
  }
  /* ссылка «Перейти к содержимому» — скрыта до получения фокуса */
  .skip-link{
    position:absolute; left:-9999px; top:auto; width:1px; height:1px;
    overflow:hidden; clip:rect(0,0,0,0); white-space:nowrap;
  }
  .skip-link:focus{
    position:fixed; top:.6rem; left:.6rem; width:auto; height:auto;
    padding:.55rem .85rem; margin:0; clip:auto; z-index:100;
    background:var(--accent); color:#fff; border-radius:4px;
    font-family:var(--sans); font-weight:700; font-size:.9rem;
  }

  /* ============ ДЕСКРИПТОР / КИКЕРЫ / ВРЕЗКИ ============ */
  .kicker{
    font-family:var(--sans); font-weight:700; text-transform:uppercase;
    letter-spacing:.09em; font-size:.72rem; color:var(--accent);
    margin:1rem 0 .4rem;
  }
  /* врезки-пояснения (не цитаты) */
  .callout{
    margin:1.6rem 0; padding:1rem 1.2rem; background:var(--card);
    border-left:3px solid var(--accent); border-radius:3px; font-size:.97em;
  }
  .callout > h4{ margin-top:0; color:var(--accent-ink); }
  .callout > p:last-child{ margin-bottom:0; }
  .callout > ul:last-child, .callout > ol:last-child{ margin-bottom:0; }
  /* атрибуция цитаты */
  .attribution{
    margin:.4rem 0 0; color:var(--muted);
    font-style:italic; font-size:.93em;
  }
  .attribution cite{ font-style:normal; }

  p{ margin:0 0 1.05rem; }

  a{ color:var(--accent); text-decoration:none;
      border-bottom:1px solid color-mix(in srgb, var(--accent) 38%, transparent);
      overflow-wrap:anywhere; }
  a:hover{ color:var(--accent-ink); border-bottom-color:currentColor; }
  /* видимый фокус для клавиатурной навигации (a11y) */
  a:focus-visible{ outline:2px solid var(--accent); outline-offset:2px; border-radius:1px; }
  /* пункты содержания: кликабельны, акцентный цвет, без подчёркивания */
  a.toc-link{ color:var(--accent); border-bottom:0; }
  a.toc-link:hover{ color:var(--accent-ink); }
  a.toc-link:focus-visible{ outline-offset:3px; }

  strong{ color:var(--ink); }
  em{ font-style:italic; }

  /* ============ СПИСКИ ============ */
  ul, ol{ margin:0 0 1.2rem; padding-left:1.4rem; }
  li{ margin:.35rem 0; }
  ol li::marker{ color:var(--accent); font-family:var(--sans); }

  /* ============ ВРЕЗКИ / ЦИТАТЫ ============ */
  blockquote{
    margin:1.6rem 0; padding:1rem 1.2rem; background:var(--card);
    border-left:3px solid var(--accent); border-radius:3px;
    font-size:.97em;
  }
  blockquote p{ margin:0 0 .6rem; }
  blockquote p:last-child{ margin-bottom:0; }
  blockquote h4{ margin-top:0; color:var(--accent-ink); }

  /* ============ ТАБЛИЦЫ ============ */
  .table-scroll{ overflow-x:auto; margin:1.6rem 0; -webkit-overflow-scrolling:touch; }
  table{
    border-collapse:collapse; width:100%; min-width:0;
    font-family:var(--sans); font-size:.86rem; line-height:1.4;
  }
  th, td{ text-align:left; padding:.55rem .7rem; border-bottom:1px solid var(--rule);
    vertical-align:top; overflow-wrap:break-word; hyphens:auto; }
  thead th{ border-bottom:2px solid var(--accent); color:var(--ink); font-weight:700; }
  /* фолбэк для старых браузеров без color-mix() */
  tbody tr:nth-child(even){ background:rgba(14,116,144,0.06); }
  tbody tr:nth-child(even){ background:color-mix(in srgb, var(--accent) 6%, transparent); }

  /* ============ ЛИНЕЙКИ ============ */
  hr{ border:0; height:1px; background:var(--rule); margin:1.8rem 0; }

  /* ============ УЗКИЕ ЭКРАНЫ ============ */
  @media (max-width:560px){
    .page{ padding:1.8rem 1.05rem 3rem; }
    table{ font-size:.76rem; }
    th, td{ padding:.4rem .45rem; }
  }

  /* ============ ПЕЧАТЬ (ч/б, экономно по тонеру) ============ */
  @page{ size:A4; margin:18mm 16mm; }
  @media print{
    :root{
      --ink:#000; --body:#000; --muted:#444; --rule:#bbb;
      --paper:#fff; --card:#fff; --accent:#000; --accent-2:#000; --accent-ink:#000;
    }
    html, body{ font-size:10.5pt; line-height:1.5; background:#fff; }
    .page{ max-width:none; margin:0; padding:0; }
    h1{ font-size:34pt; }
    h1::before{ display:none !important; }
    .reading-progress{ display:none !important; }
    .back-to-top{ display:none !important; }
    h2{ font-size:19pt; break-before:page; border-top-color:#000; }
    h3{ font-size:13pt; }
    h2, h3, h4{ break-after:avoid; }
    p, li{ orphans:3; widows:3; }
    blockquote, .callout, table, tr, img{ break-inside:avoid; }
    blockquote{ background:#fff; border-left:2px solid #000; }
    blockquote h4{ color:#000; }
    .callout{ background:#fff; border-left:2px solid #000; }
    .callout h4{ color:#000; }
    tbody tr:nth-child(even){ background:#fff; }
    thead th{ border-bottom:2px solid #000; }
    ol li::marker{ color:#000; }
    a{ color:#000; border-bottom:0; text-decoration:underline; }
    .table-scroll{ overflow:visible; }
    table{ font-size:9pt; }
    hr{ background:#ccc; }
  }
</style>
</head>
<body>
<div aria-hidden="true" class="reading-progress"><span></span></div>
<a href="#main" class="back-to-top" aria-label="Наверх" data-back-to-top><span class="back-to-top__icon" aria-hidden="true">↑</span><span class="back-to-top__label">Наверх</span></a>
<a href="#main" class="skip-link">Перейти к содержимому</a>
<main class="page" id="main">
<header class="masthead">
<h1 id="спектр">СПЕКТР</h1>
<p class="deck">$if(deck)$$deck$$else$Научно-популярный журнал об аутизме · Выпуск №$issue$$endif$</p>
<p class="date"><time datetime="$date$">$date-human$</time></p>
<hr />
<nav aria-label="Содержание выпуска">
<p>В этом выпуске:</p>
<ol>
<li><a href="#от-редакции" class="toc-link">От редакции</a></li>
<li><a href="#главное-за-месяц" class="toc-link">Главное за месяц</a></li>
<li><a href="#наука-понятным-языком" class="toc-link">Наука понятным языком</a></li>
<li><a href="#подходы-и-практика" class="toc-link">Подходы и практика</a></li>
<li><a href="#живые-истории" class="toc-link">Живые истории</a></li>
<li><a href="#культура-и-медиа" class="toc-link">Культура и медиа</a></li>
<li><a href="#родителю-на-заметку" class="toc-link">Родителю на заметку</a></li>
<li><a href="#источники" class="toc-link">Источники</a></li>
</ol>
</nav>
<p>Журнал предназначен для вдумчивых родителей детей с РАС. Каждое утверждение сопровождается ссылкой на источник. Материалы носят информационный характер и не заменяют консультацию врача.</p>
</header>
$body$
<hr />
<footer class="colophon">
<p><em>«СПЕКТР» — научно-популярный журнал об аутизме. Выпуск №$issue$ от $date-human$. Материалы носят информационный характер и не заменяют консультацию специалиста.</em></p>
</footer>
</main>
<script>
;(() => {
  const bar = document.querySelector('.reading-progress span');
  const topBtn = document.querySelector('[data-back-to-top]');
  const update = () => {
    if (bar) {
      const max = document.documentElement.scrollHeight - innerHeight;
      bar.style.width = (max > 0 ? (scrollY / max) * 100 : 0) + '%';
    }
    if (topBtn) {
      topBtn.classList.toggle('is-visible', scrollY > innerHeight * 0.5);
    }
  };
  // батчинг: чтение scrollHeight (форсирует пересчёт макета) делаем не чаще кадра
  let ticking = false;
  const requestUpdate = () => {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => { ticking = false; update(); });
  };
  addEventListener('scroll', requestUpdate, { passive: true });
  addEventListener('resize', requestUpdate, { passive: true });
  addEventListener('load', update, { once: true });
  update();

  if (topBtn) {
    topBtn.addEventListener('click', (e) => {
      e.preventDefault();
      const prefersReduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
      window.scrollTo({ top: 0, behavior: prefersReduced ? 'auto' : 'smooth' });
      topBtn.blur();
    });
  }
})();
</script>
</body>
</html>
